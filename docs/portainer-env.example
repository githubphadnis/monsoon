# Portainer stack environment — copy into Portainer → Stack → Environment variables
# Required keys marked (REQUIRED). See docker-compose.portainer.yml.

# --- App ---
APP_TIMEZONE=Europe/Amsterdam
APP_LOG_LEVEL=INFO
ALLOWED_WHATSAPP_NUMBERS=918291882204
# REQUIRED — monsoon only replies in these conversation JIDs (fail closed if empty/missing).
# Self-chat: your number + @c.us  (Message yourself)
# Group: 120363xxxxxxxxx@g.us
ALLOWED_WHATSAPP_CHAT_IDS=918291882204@c.us
# Shared family space — all allowlisted members see pooled tasks + this group's WA
# MONSOON_SHARED_CHAT_IDS=120363143633935585@g.us
MONSOON_ALLOW_SELF_CHAT=true
MONSOON_AUTO_WEBHOOK=true

# --- Postgres (REQUIRED: POSTGRES_PASSWORD) ---
POSTGRES_USER=monsoon
POSTGRES_PASSWORD=
POSTGRES_DB=monsoon
# Note: do not set DATABASE_URL in Portainer — compose builds it from POSTGRES_*.
# Avoid ! @ # in password or URL-encode if you must use them.

# --- WorkFlowy (Phase 2+) ---
WORKFLOWY_API_KEY=
WORKFLOWY_ROOT_NODE_ID=

# --- WAHA — dedicated monsoon instance (REQUIRED: WAHA_API_KEY, WAHA_DASHBOARD_PASSWORD, WHATSAPP_SWAGGER_PASSWORD) ---
WAHA_API_KEY=
WAHA_SESSION=prakalp
WAHA_DASHBOARD_USERNAME=admin
WAHA_DASHBOARD_PASSWORD=
WHATSAPP_SWAGGER_USERNAME=admin
WHATSAPP_SWAGGER_PASSWORD=
# WAHA_BASE_URL / webhook URL are fixed in compose (127.0.0.1 sidecar — see deploy-portainer.md §4)

# --- Gmail (see docs/gmail-ingestion.md) ---
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
# Leave GMAIL_SYNC_LABEL unset/empty for All Mail (includes Archive).
# GMAIL_SYNC_LABEL=INBOX
GMAIL_SYNC_PAGE_SIZE=50
# GMAIL_INCLUDE_SPAM_TRASH=true
# Omit GMAIL_SYNC_MAX_PAGES (empty value crashes older builds)

# --- Background scheduler (same-day catch-up defaults) ---
MONSOON_SCHEDULER_ENABLED=true
MONSOON_GMAIL_SYNC_INTERVAL_MINUTES=5
MONSOON_GMAIL_SYNC_BATCH_PAGES=5
MONSOON_WA_SYNC_INTERVAL_MINUTES=5
MONSOON_WA_SYNC_BATCH_CHATS=5
MONSOON_WORKFLOWY_SYNC_INTERVAL_MINUTES=20
MONSOON_REMINDER_INTERVAL_MINUTES=1

# --- Ollama on lenai ---
# Prefer lenai LAN IP if notcoolio and lenai are on the same subnet (lowest latency).
# Hostname lenai often fails inside Docker — use IP, not MagicDNS/mDNS name.
# OLLAMA_BASE_URL=http://192.168.x.x:11434
OLLAMA_BASE_URL=http://lenai:11434
# Single-model mode (all paths use this):
OLLAMA_MODEL=llama3.2
# Auto routing (optional): keep a fast parser + richer chat model.
# Pull on lenai first, e.g. `ollama pull qwen2.5:14b` and `ollama pull llama3.2`
# OLLAMA_MODEL_PARSE=qwen2.5-coder:7b
# OLLAMA_MODEL_CHAT=qwen2.5:14b
OLLAMA_TIMEOUT_SECONDS=60
# Longer wait for big chat models (0 = same as OLLAMA_TIMEOUT_SECONDS)
# OLLAMA_CHAT_TIMEOUT_SECONDS=180
MONSOON_SOUL_PROMPT=You are monsoon, Prakalp's personal capture assistant on WhatsApp. Be concrete, action-first, and brief. No corporate filler, no thank-yous.
