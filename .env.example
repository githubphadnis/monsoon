# monsoon — environment template
# Copy to .env and fill in values. Never commit .env.

# --- App ---
APP_HOST=0.0.0.0
APP_PORT=8080
APP_LOG_LEVEL=INFO
APP_TIMEZONE=Europe/Amsterdam
# Comma-separated E.164 numbers without + (who may use the bot)
ALLOWED_WHATSAPP_NUMBERS=918291882204
# Allow WhatsApp "Message yourself" capture (fromMe messages)
MONSOON_ALLOW_SELF_CHAT=true

# --- Postgres ---
POSTGRES_USER=monsoon
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=monsoon
DATABASE_URL=postgresql://monsoon:CHANGE_ME@postgres:5432/monsoon

# --- WorkFlowy ---
# https://workflowy.com/api-key
WORKFLOWY_API_KEY=
# Optional: parent node id for "Personal Capture & Reminder" root (set after first sync)
WORKFLOWY_ROOT_NODE_ID=

# --- WAHA ---
# If using bundled waha service: http://waha:3000
WAHA_BASE_URL=http://waha:3000
WAHA_API_KEY=CHANGE_ME
WAHA_SESSION=default
# Webhook path on this app (WAHA posts here)
WAHA_WEBHOOK_PATH=/api/webhooks/waha

# --- Ollama (lenai) — core ---
OLLAMA_BASE_URL=http://lenai:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TIMEOUT_SECONDS=60
# Operator personality for digests/nudges (multi-line OK in .env)
MONSOON_SOUL_PROMPT=You are monsoon, a concise personal assistant. Be practical, proactive, and brief.

# --- Scheduler ---
MORNING_DIGEST_CRON=0 7 * * *
REMINDER_POLL_SECONDS=60
